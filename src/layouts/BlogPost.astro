---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${title} — Malo Paletou`} description={description} image={heroImage}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-24">
    <!-- Back link -->
    <a
      href="/blog"
      class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition-colors mb-12"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Retour au blog
    </a>

    <!-- Header -->
    <header class="mb-12">
      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {tags.map((tag) => (
              <span class="text-xs font-medium px-2 py-1 rounded-full bg-blue-50 text-blue-700">
                {tag}
              </span>
            ))}
          </div>
        )
      }
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight mb-4">
        {title}
      </h1>
      <p class="text-lg text-gray-500">{description}</p>
      <div class="mt-6 flex items-center gap-4 text-sm text-gray-400">
        <span>{formattedDate}</span>
        {
          updatedDate && (
            <span>
              · Mis à jour le{' '}
              {updatedDate.toLocaleDateString('fr-FR', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </span>
          )
        }
      </div>
    </header>

    <!-- Hero image -->
    {
      heroImage && (
        <img
          src={heroImage}
          alt={title}
          class="w-full rounded-2xl mb-12 object-cover aspect-video"
        />
      )
    }

    <!-- Content -->
    <div
      class="prose prose-gray prose-lg max-w-none
             prose-headings:font-bold prose-headings:text-gray-900
             prose-h2:mt-16 prose-h2:mb-6
             prose-h3:mt-12 prose-h3:mb-4 prose-h3:font-bold prose-h3:text-xl
             prose-p:text-gray-600 prose-p:leading-relaxed prose-p:mb-6
             prose-strong:text-gray-900
             prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
             prose-code:bg-gray-100 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono prose-code:before:content-none prose-code:after:content-none
             prose-pre:bg-gray-900 prose-pre:text-gray-100
             prose-ul:my-6 prose-li:my-2
             [&_h3]:font-bold [&_h3]:mt-12 [&_h3]:mb-4 [&_h3]:text-xl [&_h3]:text-gray-900
             [&_h2]:mt-16 [&_h2]:mb-6"
    >
      <slot />
    </div>

    <!-- Author footer -->
    <footer class="mt-16 pt-8 border-t border-gray-100 flex items-center gap-4">
      <img
        src="/images/malo-paletou.jpg"
        alt="Malo Paletou"
        class="w-12 h-12 rounded-full object-cover object-top"
      />
      <div>
        <p class="font-medium text-gray-900 text-sm">Malo Paletou</p>
        <p class="text-sm text-gray-500">Sysadmin & entrepreneur, Toulouse</p>
      </div>
    </footer>
  </article>
</Base>
