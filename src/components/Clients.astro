---
import { activeClients, periodicClients, endedClients } from '@/data/clients';
type Tab = 'active' | 'periodic' | 'ended';
const tabs: { id: Tab; label: string; count: number }[] = [
  { id: 'active', label: 'Clients actifs', count: activeClients.length },
  { id: 'periodic', label: 'Missions ponctuelles', count: periodicClients.length },
  { id: 'ended', label: 'Missions terminées', count: endedClients.length },
];
const allGroups = {
  active: activeClients,
  periodic: periodicClients,
  ended: endedClients,
};
---
<section id="clients" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-12">
      <p class="text-sm font-semibold text-blue-600 uppercase tracking-widest mb-4">Références</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight">
        Ils m'ont fait confiance
      </h2>
      <p class="mt-4 text-gray-500 leading-relaxed">
        PME de 5 à 100 personnes, startups, associations, éditeurs de logiciels —
        dans des secteurs très variés. Ce panel d'expériences, c'est aussi ce qui
        me permet de m'adapter rapidement à votre contexte.
      </p>
    </div>
    <!-- Tabs -->
    <div class="flex flex-wrap gap-2 mb-10" role="tablist">
      {tabs.map((tab, i) => (
        <button
          role="tab"
          data-tab={tab.id}
          aria-selected={i === 0 ? 'true' : 'false'}
          class:list={[
            'tab-btn px-4 py-2 rounded-full text-sm font-medium transition-all border',
            i === 0
              ? 'bg-blue-600 text-white border-blue-600'
              : 'bg-white text-gray-600 border-gray-200 hover:border-blue-300 hover:text-blue-600',
          ]}
        >
          {tab.label}
          <span class:list={[
            'ml-2 text-xs px-1.5 py-0.5 rounded-full',
            i === 0 ? 'bg-blue-500 text-white' : 'bg-gray-100 text-gray-500',
          ]}>
            {tab.count}
          </span>
        </button>
      ))}
    </div>
    <!-- Client grids -->
    {Object.entries(allGroups).map(([key, group], gi) => (
      <div
        data-panel={key}
        class:list={['client-panel', gi !== 0 && 'hidden']}
      >
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
          {group.map((client) => (
            <a
              href={client.url}
              rel="nofollow noopener"
              target="_blank"
              class="group relative bg-white border border-gray-200 rounded-xl p-4 flex flex-col items-center text-center hover:border-blue-200 hover:shadow-md transition-all overflow-hidden"
            >
              <!-- Logo: Google favicon → lettre -->
              <div class="w-12 h-12 mb-3 rounded-xl overflow-hidden flex items-center justify-center bg-white border border-gray-100 shadow-sm">
                <img
                  src={`https://www.google.com/s2/favicons?domain=${client.logoDomain ?? client.domain}&sz=64`}
                  alt={client.label}
                  class="w-10 h-10 object-contain logo-img"
                  loading="lazy"
                  data-domain={client.logoDomain ?? client.domain}
                  data-label={client.label[0]}
                />
              </div>
              <p class="text-xs font-semibold text-gray-900 leading-tight mb-1">{client.label}</p>
              <p class="text-xs text-gray-400 leading-tight">{client.description.fr}</p>
              <!-- Screenshot overlay on hover -->
              <div class="absolute inset-0 bg-gray-900/90 opacity-0 group-hover:opacity-100 transition-opacity rounded-xl overflow-hidden">
                <img
                  src={`/screenshots/${client.domain}.jpg`}
                  alt={`${client.label} website`}
                  class="absolute inset-0 w-full h-full object-cover opacity-50"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
                <div class="absolute inset-0 flex items-center justify-center p-3">
                  <span class="text-xs text-white font-medium text-center bg-gray-900/70 px-2 py-1 rounded">{client.domain} →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
<script>
  // Logo fallback: Google favicon → letter avatar
  document.querySelectorAll<HTMLImageElement>('.logo-img').forEach((img) => {
    const letter = img.dataset.label!;
    img.addEventListener('error', () => {
      const span = document.createElement('span');
      span.className = 'w-10 h-10 rounded-lg bg-blue-600 text-white text-base font-bold flex items-center justify-center';
      span.textContent = letter;
      img.replaceWith(span);
    });
  });

  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLDivElement>('.client-panel');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab!;
      tabs.forEach((t) => {
        const active = t.dataset.tab === target;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('bg-blue-600', active);
        t.classList.toggle('text-white', active);
        t.classList.toggle('border-blue-600', active);
        t.classList.toggle('bg-white', !active);
        t.classList.toggle('text-gray-600', !active);
        t.classList.toggle('border-gray-200', !active);
        const badge = t.querySelector('span')!;
        badge.classList.toggle('bg-blue-500', active);
        badge.classList.toggle('text-white', active);
        badge.classList.toggle('bg-gray-100', !active);
        badge.classList.toggle('text-gray-500', !active);
      });
      panels.forEach((panel) => {
        panel.classList.toggle('hidden', panel.dataset.panel !== target);
      });
    });
  });
</script>
