---
---
<section id="contact" class="py-24 bg-night">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <!-- Left -->
      <div>
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-4">Contact</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white leading-tight mb-6">
          Discutons de<br />votre infrastructure.
        </h2>
        <p class="text-gray-400 leading-relaxed mb-10">
          Tout commence par une discussion. Je propose un audit initial gratuit pour
          comprendre votre situation et voir comment je peux vous aider — sans engagement.
        </p>
        <!-- Contact methods -->
        <div class="space-y-5">
          <a
            href="https://cal.com/malo-paletou"
            class="flex items-center gap-4 p-4 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 transition-colors group"
          >
            <div class="w-10 h-10 rounded-lg bg-blue-600 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-white font-semibold text-sm">Réserver un appel</p>
              <p class="text-gray-400 text-xs">cal.com/malo-paletou</p>
            </div>
            <svg class="w-4 h-4 text-gray-500 group-hover:text-gray-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="mailto:contact@malopaletou.pro"
            class="flex items-center gap-4 p-4 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 transition-colors group"
          >
            <div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-white font-semibold text-sm">Email</p>
              <p class="text-gray-400 text-xs">contact@malopaletou.pro</p>
            </div>
            <svg class="w-4 h-4 text-gray-500 group-hover:text-gray-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="tel:+33649980151"
            class="flex items-center gap-4 p-4 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 transition-colors group"
          >
            <div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-white font-semibold text-sm">Téléphone</p>
              <p class="text-gray-400 text-xs">+33 6 49 98 01 51</p>
            </div>
            <svg class="w-4 h-4 text-gray-500 group-hover:text-gray-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
      <!-- Right: profile recap + socials -->
      <div class="lg:pt-12">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-8">
          <div class="flex items-center gap-4 mb-6">
            <img
              src="/images/malo-paletou-portrait.jpg"
              alt="Malo Paletou"
              class="w-16 h-16 rounded-full object-cover object-top border-2 border-white/20"
            />
            <div>
              <p class="font-bold text-white text-lg">Malo Paletou</p>
              <p class="text-gray-400 text-sm">Sysadmin & entrepreneur · Toulouse — Paris</p>
            </div>
          </div>
          <div class="space-y-3 mb-8">
            <div class="flex justify-between text-sm">
              <span class="text-gray-400">Tarif missions</span>
              <span class="text-white font-medium">700 €/jour · à l'heure possible</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-400">Maintenance</span>
              <span class="text-white font-medium">dès 150 €/mois</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-400">Audit initial</span>
              <span class="text-green-400 font-medium">Gratuit</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-400">Disponibilité</span>
              <span class="text-white font-medium flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
                Disponible
