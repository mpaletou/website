---
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<section id="blog" class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="text-sm font-semibold text-blue-600 uppercase tracking-widest mb-4">Blog</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
          Ce que j'écris
        </h2>
        <p class="mt-2 text-gray-500">
          Infra, sauvegardes, entrepreneuriat — et ce qui me passe par la tête.
        </p>
      </div>
      <a
        href="/blog"
        class="hidden sm:inline-flex items-center gap-2 text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors"
      >
        Tous les articles
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
    {
      posts.length === 0 ? (
        <div class="text-center py-16 text-gray-400">
          <p class="text-lg mb-2">Bientôt des articles ici.</p>
          <p class="text-sm">En attendant, je poste régulièrement sur LinkedIn.</p>
          <a
            href="https://www.linkedin.com/in/malo-paletou/"
            class="inline-flex items-center gap-2 mt-4 text-sm font-medium text-blue-600 hover:underline"
          >
            Voir mon LinkedIn →
          </a>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {posts.map((post) => {
            const date = post.data.pubDate.toLocaleDateString('fr-FR', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });
            return (
              <a href={`/blog/${post.slug}`} class="group block">
                <article class="bg-white rounded-2xl p-6 border border-gray-200 group-hover:border-blue-200 group-hover:shadow-md transition-all h-full flex flex-col">
                  <div class="flex flex-wrap gap-1.5 mb-4">
                    {post.data.tags.map((tag) => (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-blue-50 text-blue-600 font-medium">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <h3 class="font-semibold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug mb-3 flex-1">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-gray-500 leading-relaxed mb-4">
                    {post.data.description}
                  </p>
                  <span class="text-xs text-gray-400">{date}</span>
                </article>
              </a>
            );
          })}
        </div>
      )
    }
    <div class="text-center mt-8 sm:hidden">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors"
      >
        Tous les articles
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
