---
const navLinks = [
  { href: '#a-propos', label: 'À propos' },
  { href: '#services', label: 'Services' },
  { href: '#datashelter', label: 'Datashelter' },
  { href: '#clients', label: 'Clients' },
  { href: '/blog', label: 'Blog' },
  { href: '#contact', label: 'Contact' },
];
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-6">
    <!-- Logo -->
    <a href="/" class="font-bold text-lg tracking-tight text-white shrink-0" id="nav-logo">
      malopaletou<span class="text-blue-400">.</span>pro
    </a>

    <!-- Desktop links -->
    <div class="hidden lg:flex items-center gap-6 flex-1 justify-center">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link text-sm font-medium text-gray-300 hover:text-white transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- Phone + CTA -->
    <div class="hidden md:flex items-center gap-3 shrink-0">
      <a
        href="tel:+33649980151"
        class="nav-phone flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-200 transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span class="hidden lg:inline">+33 6 49 98 01 51</span>
      </a>
      <span class="text-gray-700 hidden lg:inline">·</span>
      <a
        href="https://cal.com/malo-paletou"
        class="inline-flex items-center px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition-colors"
      >
        Prendre un appel
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden text-white p-1"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 shadow-lg">
    <div class="px-4 py-4 space-y-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="block px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      <div class="pt-3 space-y-2">
        <a
          href="tel:+33649980151"
          class="flex items-center gap-2 px-3 py-2 text-sm text-gray-600"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          +33 6 49 98 01 51
        </a>
        <a
          href="https://cal.com/malo-paletou"
          class="block w-full text-center px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors"
        >
          Prendre un appel
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('nav')!;
  const logo = document.getElementById('nav-logo')!;
  const links = nav.querySelectorAll<HTMLElement>('.nav-link');
  const phone = document.getElementById('nav')!.querySelector<HTMLElement>('.nav-phone');
  const toggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  const hasHero = !!document.querySelector('section[aria-label="Introduction"]');

  function updateNav() {
    const scrolled = !hasHero || window.scrollY > 60;
    nav.classList.toggle('bg-white', scrolled);
    nav.classList.toggle('shadow-sm', scrolled);
    nav.classList.toggle('border-b', scrolled);
    nav.classList.toggle('border-gray-100', scrolled);
    nav.classList.toggle('bg-transparent', !scrolled);

    logo.classList.toggle('text-white', !scrolled);
    logo.classList.toggle('text-gray-900', scrolled);
    const dot = logo.querySelector('span')!;
    dot.className = scrolled ? 'text-blue-600' : 'text-blue-400';

    links.forEach((link) => {
      link.classList.toggle('text-gray-300', !scrolled);
      link.classList.toggle('hover:text-white', !scrolled);
      link.classList.toggle('text-gray-600', scrolled);
      link.classList.toggle('hover:text-gray-900', scrolled);
    });

    if (phone) {
      phone.classList.toggle('text-gray-400', !scrolled);
      phone.classList.toggle('hover:text-gray-200', !scrolled);
      phone.classList.toggle('text-gray-500', scrolled);
      phone.classList.toggle('hover:text-gray-700', scrolled);
    }

    toggle.classList.toggle('text-white', !scrolled);
    toggle.classList.toggle('text-gray-700', scrolled);
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  toggle.addEventListener('click', () => {
    const isHidden = mobileMenu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isHidden));
    iconOpen.classList.toggle('hidden', !isHidden);
    iconClose.classList.toggle('hidden', isHidden);
  });

  mobileMenu.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
