---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base
  title="Blog — Malo Paletou"
  description="Articles sur l'infra, les sauvegardes, le DevOps et l'entrepreneuriat indépendant. Par Malo Paletou, sysadmin freelance à Toulouse, fondateur de Datashelter."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-24">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition-colors mb-12"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Accueil
    </a>

    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-2">Blog</h1>
    <p class="text-gray-500 mb-16">
      Infra, sauvegardes, entrepreneuriat — et parfois autre chose.
    </p>

    {
      posts.length === 0 ? (
        <p class="text-gray-400 py-12 text-center">Aucun article pour l'instant. Revenez bientôt.</p>
      ) : (
        <ul class="space-y-8">
          {posts.map((post) => {
            const date = post.data.pubDate.toLocaleDateString('fr-FR', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });
            return (
              <li>
                <a href={`/blog/${post.slug}/`} class="group block">
                  <article class="p-6 rounded-2xl border border-gray-100 hover:border-blue-200 hover:bg-blue-50/30 transition-all">
                    <div class="flex flex-wrap gap-2 mb-3">
                      {post.data.tags.map((tag) => (
                        <span class="text-xs font-medium px-2 py-1 rounded-full bg-gray-100 text-gray-600">
                          {tag}
                        </span>
                      ))}
                    </div>
                    <h2 class="text-xl font-semibold text-gray-900 group-hover:text-blue-600 transition-colors mb-2">
                      {post.data.title}
                    </h2>
                    <p class="text-gray-500 text-sm leading-relaxed mb-4">
                      {post.data.description}
                    </p>
                    <span class="text-xs text-gray-400">{date}</span>
                  </article>
                </a>
              </li>
            );
          })}
        </ul>
      )
    }
  </div>
</Base>
